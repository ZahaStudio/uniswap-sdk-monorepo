{
  "name": "@zahastudio/uniswap-sdk-react",
  "version": "1.0.0",
  "keywords": [
    "tanstack-intent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZahaStudio/uniswap-sdk-monorepo.git"
  },
  "files": [
    "dist/**",
    "docs/**",
    "README.md",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@uniswap/v3-sdk": "^3.30.0",
    "@uniswap/v4-sdk": "^2.1.0",
    "@zahastudio/uniswap-sdk": "workspace:*"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@tanstack/intent": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "viem": ">=2.0.0",
    "wagmi": ">=2.0.0"
  },
  "intent": {
    "version": 1,
    "repo": "ZahaStudio/uniswap-sdk-monorepo",
    "docs": "docs/",
    "requires": [
      "@zahastudio/uniswap-sdk"
    ]
  }
}
