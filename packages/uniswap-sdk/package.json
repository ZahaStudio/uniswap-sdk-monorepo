{
  "name": "@zahastudio/uniswap-sdk",
  "version": "0.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZahaStudio/uniswap-sdk-monorepo.git"
  },
  "files": [
    "dist/**",
    "docs/**",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "pnpm run typecheck && pnpm run test",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@uniswap/permit2-sdk": "^1.4.0",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/universal-router-sdk": "^5.1.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "@uniswap/v4-sdk": "^2.0.0",
    "hookmate": "^0.5.1",
    "lru-cache": "^11.2.7"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "viem": "catalog:"
  }
}
