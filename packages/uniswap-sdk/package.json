{
  "name": "@zahastudio/uniswap-sdk",
  "version": "0.5.0",
  "keywords": [
    "tanstack-intent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZahaStudio/uniswap-sdk-monorepo.git"
  },
  "files": [
    "dist/**",
    "docs/**",
    "README.md",
    "skills"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "pnpm run typecheck && pnpm run test",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@uniswap/permit2-sdk": "^1.4.0",
    "@uniswap/sdk-core": "^7.13.0",
    "@uniswap/universal-router-sdk": "^5.1.0",
    "@uniswap/v3-sdk": "^3.30.0",
    "@uniswap/v4-sdk": "^2.0.0",
    "hookmate": "^0.5.1",
    "lru-cache": "11.2.7"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@tanstack/intent": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "viem": "catalog:",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "viem": "catalog:"
  },
  "intent": {
    "version": 1,
    "repo": "ZahaStudio/uniswap-sdk-monorepo",
    "docs": "docs/"
  }
}
