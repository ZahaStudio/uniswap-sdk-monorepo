{
  "name": "uniswap-sdk-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A TypeScript SDK for interacting with **Uniswap v4** — providing pool queries, token swaps, liquidity management, and Permit2 approvals out of the box. Includes first-class React bindings with hooks for every operation.",
  "keywords": [],
  "homepage": "https://github.com/ZahaStudio/uniswap-sdk-monorepo#readme",
  "bugs": {
    "url": "https://github.com/ZahaStudio/uniswap-sdk-monorepo/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZahaStudio/uniswap-sdk-monorepo.git"
  },
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:lib": "turbo run build --filter='!@acme/*'",
    "dev": "turbo run dev",
    "dev:lib": "turbo run dev --filter='!@acme/*'",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix --fix-suggestions --fix-dangerously",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "intent:validate": "pnpm --filter @zahastudio/uniswap-sdk exec intent validate && pnpm --filter @zahastudio/uniswap-sdk-react exec intent validate",
    "intent:stale": "intent stale",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "anvil": "anvil --fork-url https://mainnet.gateway.tenderly.co --chain-id 1 --mnemonic-seed-unsafe 1337 --block-time 4"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "@tanstack/intent": "catalog:",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.63.0",
    "taze": "^19.11.0",
    "turbo": "^2.9.9",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.4"
}
